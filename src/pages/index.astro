---
const projectStatus = [
  ["Production readiness", "Not ready"],
  ["Validated strategies", "0"],
  ["Live trading approval", "None"],
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>TWStock Research Console v0.1</title>
    <style>
      :root {
        color-scheme: light dark;
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", sans-serif;
        line-height: 1.5;
        background: #0f172a;
        color: #e2e8f0;
      }

      body {
        min-height: 100vh;
        margin: 0;
        display: grid;
        place-items: center;
      }

      main {
        width: min(92vw, 48rem);
        padding: 3rem;
        border: 1px solid rgb(148 163 184 / 0.25);
        border-radius: 1.5rem;
        background: linear-gradient(145deg, rgb(15 23 42 / 0.92), rgb(30 41 59 / 0.84));
        box-shadow: 0 1.5rem 4rem rgb(2 6 23 / 0.35);
      }

      p {
        color: #cbd5e1;
      }

      .eyebrow {
        margin: 0 0 0.75rem;
        color: #38bdf8;
        font-size: 0.875rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      h1 {
        margin: 0;
        font-size: clamp(2rem, 5vw, 3.5rem);
        line-height: 1.05;
      }

      .status-list {
        display: grid;
        gap: 1rem;
        padding: 0;
        margin: 2rem 0 0;
        list-style: none;
      }

      .status-list li {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        padding: 1rem;
        border: 1px solid rgb(148 163 184 / 0.2);
        border-radius: 0.875rem;
        background: rgb(15 23 42 / 0.55);
      }

      .status-label {
        color: #94a3b8;
      }

      .status-value {
        font-weight: 700;
      }
    </style>
  </head>
  <body>
    <main>
      <p class="eyebrow">System bootstrap</p>
      <h1>TWStock Research Console v0.1</h1>
      <p>
        Minimal static website scaffold for the TWStock research platform. This
        bootstrap page does not include strategy rules, backtesting, registry
        data, authentication, APIs, or investment recommendations.
      </p>
      <ul class="status-list" aria-label="Project status">
        {
          projectStatus.map(([label, value]) => (
            <li>
              <span class="status-label">{label}</span>
              <span class="status-value">{value}</span>
            </li>
          ))
        }
      </ul>
    </main>
  </body>
</html>
